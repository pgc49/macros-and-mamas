# Client-side Vite env (public under RLS — not secrets).
# Copy to .env for local `npm run dev`.
# Also set these in Cloudflare Pages → Settings → Environment variables
# (Production + Preview) so `npm run build` embeds them.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional public URLs — buttons/links hide if unset
# VITE_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/...
# VITE_FULLSCRIPT_ELECTROLYTES_URL=https://...
# VITE_FULLSCRIPT_SLEEP_URL=https://...
# VITE_FULLSCRIPT_DIGESTION_URL=https://...
