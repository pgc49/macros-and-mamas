# Cloudflare Pages headers — keep HTML fresh after deploys (avoids Chrome white screens
# from a cached index.html pointing at old hashed JS that no longer matches).

/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
