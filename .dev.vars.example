# Copy to .dev.vars for local `npx wrangler pages dev`.
# NEVER commit .dev.vars — it is gitignored.
# Set the same values in Cloudflare Pages → Settings → Environment variables
# (Production + Preview). Use encrypted/secret for every key below.

# OpenRouter (meal photo AI)
OPENROUTER_API_KEY=replace-me

# Stripe Checkout ($149 product) — use test mode first
STRIPE_SECRET_KEY=replace-me
STRIPE_PRICE_ID=replace-me
STRIPE_WEBHOOK_SECRET=replace-me

# Supabase — URL is public; the server key is webhook-only (never ship to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-me
# Service role also invokes Supabase Edge Functions (welcome / approve / refund emails).
# RESEND_API_KEY lives in Supabase secrets — not here.
